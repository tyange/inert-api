# 서버
PORT=8080
BASE_URL=https://inert.example.com

# 데이터베이스
DATABASE_PATH=./data/inert.db

# JWT
JWT_SECRET=your-secret-key-change-this

# Lightsail Object Storage (S3 호환)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-1
AWS_ENDPOINT_URL=https://s3.ap-northeast-1.amazonaws.com
S3_BUCKET_NAME=inert

# CDN
CDN_BASE_URL=https://your-cdn.example.com

# 업로드 제한 (기본 20MB)
UPLOAD_MAX_BYTES=20971520

# CORS (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3000,https://inert.example.com
